{
  "name": "frogop",
  "version": "0.1.0",
  "description": "Options Protocol on OPNet - Bitcoin L1 Smart Contracts",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "npx asc src/index.ts --target release",
    "build:factory": "npx asc src/options-factory/index.ts --target factory --measure",
    "build:pool": "npx asc src/options-pool/index.ts --target pool --measure",
    "build:debug": "npx asc src/index.ts --target debug",
    "build:tests": "tsc -p tests/tsconfig.json",
    "test": "npm run build && npx tsx tests/OptionsFactory.test.ts",
    "test:watch": "tsc -p tests/tsconfig.json --watch",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf build tests/dist"
  },
  "keywords": [
    "opnet",
    "bitcoin",
    "options",
    "defi",
    "smart-contracts"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@btc-vision/as-bignum": "0.1.2",
    "@btc-vision/btc-runtime": "1.11.0-rc.7"
  },
  "devDependencies": {
    "@assemblyscript/loader": "0.28.9",
    "@btc-vision/assemblyscript": "0.29.2",
    "@btc-vision/opnet-transform": "1.1.0",
    "@btc-vision/unit-test-framework": "^1.0.0-beta.0",
    "@eslint/js": "9.39.2",
    "@types/node": "22.7.0",
    "eslint": "9.39.2",
    "rimraf": "6.0.1",
    "typescript": "5.6.3"
  }
}
