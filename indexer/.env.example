# FroGop Indexer — Cloudflare Workers configuration
#
# Non-secret vars: set in wrangler.toml [vars] section (already pre-filled)
# Secrets (if any): set via `wrangler secret put SECRET_NAME`
#
# This file is for reference only. Workers do NOT read .env files.
# Use `wrangler dev` for local development (reads wrangler.toml [vars] automatically).
#
# ── Local dev with wrangler ──────────────────────────────────────────────────
#
#   npm run db:migrate:local   # initialise local D1 SQLite
#   npm run dev                # start local Worker at http://localhost:8787
#
# ── Production deploy ────────────────────────────────────────────────────────
#
#   npm run db:create          # provision D1 once (copy id → wrangler.toml)
#   npm run db:migrate         # apply schema.sql to production D1
#   wrangler deploy            # or: push to master → CI auto-deploys
#
# ── All config vars ──────────────────────────────────────────────────────────
#
# OPNET_NETWORK      = "testnet"
# OPNET_RPC_URL      = "https://testnet.opnet.org"
# POOL_ADDRESSES     = "opt1sqp30j..."   (space-separated)
# FACTORY_ADDRESS    = "opt1sqz4wm..."
# MAX_BLOCKS_PER_RUN = "50"
