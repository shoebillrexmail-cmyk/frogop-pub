# FroGop Frontend Environment Variables

# Network: regtest, testnet, or mainnet
VITE_OPNET_NETWORK=testnet

# RPC URL (optional, defaults to network default)
# VITE_OPNET_RPC_URL=https://testnet.opnet.org

# Indexer API URL (optional — pages fall back to on-chain RPC if unset)
# VITE_INDEXER_URL=https://api.frogop.net

# Deployed contract addresses
VITE_FACTORY_ADDRESS=
VITE_POOL_TEMPLATE_ADDRESS=

# NativeSwap contract address (optional — enables MOTO/PILL price ratio display)
# VITE_NATIVESWAP_ADDRESS=
