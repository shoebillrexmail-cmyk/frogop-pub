# Frontend — Production (OPNet Mainnet)
# Use this file when switching from testnet to mainnet.
# See docs/deployment/MAINNET_MIGRATION.md for the full checklist.
#
# Usage:
#   cp frontend/.env.mainnet .env.production
#   docker compose -f docker-compose.prod.yml up -d --build

VITE_OPNET_NETWORK=mainnet
VITE_OPNET_RPC_URL=https://mainnet.opnet.org

# Mainnet contract addresses (fill in after mainnet deployment)
VITE_FACTORY_ADDRESS=
VITE_POOL_TEMPLATE_ADDRESS=
