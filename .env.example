# OPNet Configuration
# Copy this file to .env and fill in your values

# Your 24-word mnemonic phrase (required for deployment)
# Generate with: node -e "const {Mnemonic,MnemonicStrength}=require('@btc-vision/transaction');console.log(Mnemonic.generate(MnemonicStrength.MAXIMUM).phrase)"
OPNET_MNEMONIC="replace_with_your_24_word_mnemonic_phrase"

# Network: regtest, testnet, or mainnet
OPNET_NETWORK="regtest"

# RPC URL (optional, defaults to network default)
# OPNET_RPC_URL="https://regtest.opnet.org"
