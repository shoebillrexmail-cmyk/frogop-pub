{
  "targets": {
    "factory": {
      "outFile": "build/OptionsFactory.wasm",
      "use": ["abort=src/options-factory/index/abort"],
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    },
    "pool": {
      "outFile": "build/OptionsPool.wasm",
      "use": ["abort=src/options-pool/index/abort"],
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    },
    "debug": {
      "outFile": "build/debug/frogop.wasm",
      "textFile": "build/debug/frogop.wat",
      "sourceMap": true
    }
  },
  "options": {
    "transform": "@btc-vision/opnet-transform",
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "exportStart": "start"
  }
}
