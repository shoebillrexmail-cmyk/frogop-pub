{
  "targets": {
    "factory": {
      "outFile": "build/OptionsFactory.wasm",
      "textFile": "build/OptionsFactory.wat",
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    },
    "pool": {
      "outFile": "build/OptionsPool.wasm",
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    },
    "three-field": {
      "outFile": "build/ThreeFieldContract.wasm",
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    },
    "four-field": {
      "outFile": "build/FourFieldContract.wasm",
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    },
    "debug": {
      "outFile": "build/debug/frogop.wasm",
      "textFile": "build/debug/frogop.wat",
      "sourceMap": true
    },
    "release": {
      "outFile": "build/release/frogop.wasm",
      "textFile": "build/release/frogop.wat",
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": false
    }
  },
  "options": {
    "transform": "@btc-vision/opnet-transform",
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 10,
    "maximumMemory": 100,
    "exportStart": "start"
  }
}
